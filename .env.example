# Put real values in `.env.local` at the project root (git-ignored).
# Hardhat deploy reads `PRIVATE_KEY` from `.env.local` as well.

# Ritual PFP NFT contract (set after `npm run deploy:pfp` on ritual network)
NEXT_PUBLIC_RITUAL_PFP_ADDRESS=

# Optional: override default public RPC for the app wallet transport
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Optional: block explorer base URL (no trailing slash); defaults to Ritual explorer
NEXT_PUBLIC_RITUAL_EXPLORER_URL=https://explorer.ritualfoundation.org

# Deploy only — private key with RITUAL for gas on chain 1979 (never commit real keys)
PRIVATE_KEY=

# Deploy / Hardhat — defaults to Ritual public RPC if unset
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
